{
  "npm.packageManager": "pnpm",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.rules.customizations": [
    // Silence some warnings that will get auto-fixed
    { "rule": "perfectionist/*", "severity": "off", "fixable": true },
    { "rule": "curly", "severity": "off", "fixable": true },
    { "rule": "object-shorthand", "severity": "off", "fixable": true }
  ],
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "editor.formatOnSaveMode": "file",
  "typescript.tsdk": "node_modules/typescript/lib",
  "[javascript][typescript][typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "piny.project_settings": {
    "open-pages": ["pinyfakepage.html"],
    "app-routes": {
      "routes": [
        "/",
        "/(frontend)",
        "/(frontend)/biking-adventures",
        "/(frontend)/destinations",
        "/(frontend)/holiday-packages",
        "/(frontend)/posts",
        "/(frontend)/search",
        "/about/about",
        "/about/about-ladakh",
        "/about/our-services",
        "/about/our-team",
        "/contact",
        "/disclaimer",
        "/gallery",
        "/guides-and-staffs",
        "/home",
        "/hooks/revalidatePage",
        "/how-to-reach",
        "/http://192.168.31.174:3000",
        "/http://localhost:3000",
        "/https://3000-firebase-tw3-web-ladakhmoto-1-1764556844641.cluster-w5vd22whf5gmav2vgkomwtc4go.cloudworkstations.dev/",
        "/https://localhost:3000",
        "/https://localhost:3000/biking-adventures/leh-ladakh-adventures",
        "/https:localhost:3000",
        "/our-core-values",
        "/privacy-policy",
        "/seed-pages",
        "/terms-and-conditions",
        "/why-travel-with-us"
      ],
      "current_route": "/guides-and-staffs"
    },
    "urls": {
      "pinyfakepage.html": {
        "open-page-views": [
          {
            "w": 320,
            "h": 800
          }
        ]
      }
    },
    "recent-classes": ["a", "s", "-", "t", "n", "o", "f"],
    "component-settings": {
      "src/payload.config.ts:::Temp": {
        "route": "/gallery"
      },
      "src/endpoints/seed/pages/guides-and-staffs.ts:::Temp": {
        "route": null
      }
    }
  },
  "editor.tabSize": 4
}
