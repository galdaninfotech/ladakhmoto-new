    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.12",
    "payload": "3.79.0",
    "payload-plugin-mcp": "^1.4.1",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.1",
    "react-aria-components": "^1.14.0",
    "react-dom": "19.2.1",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "7.55.0",
    "react-icons": "^5.5.0",
    "react-scan": "^0.4.3",
    "recharts": "^3.6.0",
    "sharp": "0.34.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
